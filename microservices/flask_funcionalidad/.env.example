# Modo de notificaciones: MOCK (no envia correo) o SMTP (envio real)
NOTIFICATION_SENDER=MOCK

# Configuracion SMTP (usar cuando NOTIFICATION_SENDER=SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_password_o_app_password
SMTP_FROM_EMAIL=tu_correo@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Flask
PORT=5001
FLASK_DEBUG=1
