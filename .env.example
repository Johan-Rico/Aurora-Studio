# =========================
# Flask notification service
# =========================
# MOCK: no envia correo, solo registra en logs
# SMTP: intenta envio real por SMTP
NOTIFICATION_SENDER=MOCK

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Flask runtime
PORT=5001
FLASK_DEBUG=0
